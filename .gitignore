# Игнорировать папки сборки
build-*/
build/
*.pro.user
*.pro.user.*

# Игнорировать сгенерированные файлы Qt
Makefile
Makefile.*
*.o
*.moc
*.moc_*
*.qrc
*.ui
*.qmake.stash

# Игнорировать исполняемые файлы
*.exe
*.app
*.dll
*.so
*.a
*.lib

# Игнорировать временные файлы
*.tmp
*.swp
*.bak
*.log

# Игнорировать папки IDE
.vscode/
.idea/
*.code-workspace

# Игнорировать локальные настройки Qt
*.local
*.local.*

# Игнорировать файлы базы данных (если они есть в проекте)
*.db
*.sqlite
*.sqlite3

# Игнорировать папку с зависимостями (если используется)
dependencies/
